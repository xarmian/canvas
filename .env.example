# =============================================================================
# Canvas — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Connection string for PostgreSQL.
# Default matches the docker-compose.yml dev services.
DATABASE_URL="postgresql://canvas:canvas@localhost:5432/canvas"

# -----------------------------------------------------------------------------
# Authentication (Better Auth)
# -----------------------------------------------------------------------------
# Secret key for signing sessions/tokens. Generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-to-a-random-secret"

# The public URL of your Canvas instance (used for OAuth callbacks, etc.)
BETTER_AUTH_URL="http://localhost:5173"

# -----------------------------------------------------------------------------
# Asset Storage (S3-compatible)
# -----------------------------------------------------------------------------
# S3-compatible endpoint. Default matches MinIO from docker-compose.yml.
# If port 9000 is in use, change MINIO_PORT in docker-compose and update this.
S3_ENDPOINT="http://localhost:9002"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="canvas"
S3_REGION="us-east-1"

# Public URL for accessing stored assets (browser-reachable).
# For dev, this matches the local MinIO port. In production with Docker,
# S3_ENDPOINT may be an internal hostname (e.g. http://minio:9000) —
# set this to the externally reachable URL instead.
S3_PUBLIC_URL="http://localhost:9002/canvas"

# Set to "true" to use local filesystem storage instead of S3.
# Useful for development without Docker. Files are stored in .local-storage/
STORAGE_LOCAL="false"

# -----------------------------------------------------------------------------
# App Settings
# -----------------------------------------------------------------------------
# The public-facing URL of your Canvas instance (used for OG image URLs, etc.)
PUBLIC_APP_URL="http://localhost:5173"
